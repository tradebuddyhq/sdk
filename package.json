{
  "name": "@tradebuddy/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Trade Buddy API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [

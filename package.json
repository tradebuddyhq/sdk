  "keywords": [
    "tradebuddy",
    "trade-buddy",
    "sdk",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
